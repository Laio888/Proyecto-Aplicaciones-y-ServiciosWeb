@page "{id:int}"
@model ApiKnowledgeMap.Pages.AspectoNormativo.EliminarModel
@{
    ViewData["Title"] = "Eliminar Característica de Innovación";
}

<h2>¿Eliminar esta característica?</h2>

<div class="card mt-3">
    <div class="card-body">
        <p><strong>ID:</strong> @Model.Item.Id</p>
        <p><strong>Tipo:</strong> @Model.Item.Tipo</p>
        <p><strong>Descripción:</strong> @Model.Item.Descripcion</p>
        <p><strong>Fuente:</strong> @Model.Item.Fuente</p>
    </div>
</div>

<form method="post" class="mt-3">
    <input type="hidden" asp-for="Item.Id" />
    <button type="submit" class="btn btn-danger">Sí, eliminar</button>
    <a href="/AspectoNormativo" class="btn btn-secondary">Cancelar</a>
</form>