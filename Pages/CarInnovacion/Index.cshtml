@page
@model ApiKnowledgeMap.Pages.CarInnovacion.IndexModel
@{
    ViewData["Title"] = "Características de Innovación";
}

<h2>Características de Innovación</h2>
<a href="/CarInnovacion/Crear" class="btn btn-success mb-3">+ Nuevo</a>

<table class="table table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Nombre</th>
            <th>Tipo</th>
            <th>Descripción</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Items)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Nombre</td>
                <td>@item.Tipo</td>
                <td>@item.Descripcion</td>
                <td>
                    <a href="/CarInnovacion/Editar/@item.Id" class="btn btn-sm btn-warning">Editar</a>
                    <a href="/CarInnovacion/Eliminar/@item.Id" class="btn btn-sm btn-danger">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>