@page
@model ApiKnowledgeMap.Pages.Enfoque.IndexModel
@{
    ViewData["Title"] = "Enfoque";
}

<h2>Enfoque</h2>
<a href="/Enfoque/Crear" class="btn btn-success mb-3">+ Nuevo</a>

<table class="table table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Nombre</th>
            <th>Tipo</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Items)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Nombre</td>
                <td>@item.Descripcion</td>
                <td>
                    <a href="/Enfoque/Editar/@item.Id" class="btn btn-sm btn-warning">Editar</a>
                    <a href="/Enfoque/Eliminar/@item.Id" class="btn btn-sm btn-danger">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>