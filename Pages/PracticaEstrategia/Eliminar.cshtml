@page "{id:int}"
@model ApiKnowledgeMap.Pages.PracticaEstrategia.EliminarModel
@{
    ViewData["Title"] = "Eliminar Práctica Estratégica";
}

<h2>¿Eliminar esta práctica?</h2>

<div class="card mt-3">
    <div class="card-body">
        <p><strong>ID:</strong> @Model.Item.Id</p>
        <p><strong>Nombre:</strong> @Model.Item.Nombre</p>
        <p><strong>Tipo:</strong> @Model.Item.Tipo</p>
        <p><strong>Descripción:</strong> @Model.Item.Descripcion</p>
    </div>
</div>

<form method="post" class="mt-3">
    <input type="hidden" asp-for="Item.Id" />
    <button type="submit" class="btn btn-danger">Sí, eliminar</button>
    <a href="/PracticaEstrategia" class="btn btn-secondary">Cancelar</a>
</form>