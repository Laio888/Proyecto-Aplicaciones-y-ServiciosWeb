@{
    ViewData["Title"] = "Gestión de Enfoques";
}

<!DOCTYPE html>
<html>

<head>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

</head>

<body class="container mt-4">

    <h2 class="mb-4">Gestión de Enfoques</h2>

    <button class="btn btn-primary mb-3" onclick="nuevo()">Nuevo Enfoque</button>

    <table class="table table-bordered table-striped">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Nombre</th>
                <th>Descripcion</th>
                <th style="width:200px">Acciones</th>
            </tr>
        </thead>

        <tbody id="tabla"></tbody>
    </table>


    <!-- MODAL -->
    <div class="modal fade" id="modalEnfoque" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">

                <div class="modal-header">
                    <h5 class="modal-title">Enfoque</h5>
                </div>

                <div class="modal-body">

                    <div class="mb-3">
                        <label>ID</label>
                        <input type="number" id="id" class="form-control">
                    </div>

                    <label class="form-label">Nombre</label>
                    <input type="text" id="nombre" class="form-control">

                    <label class="form-label">Descripcion</label>
                    <textarea id="descripcion" class="form-control"></textarea>

                </div>

                <div class="modal-footer">
                    <button class="btn btn-success" onclick="guardar()">Guardar</button>
                    <button class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                </div>

            </div>
        </div>
    </div>


    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>

        const api = "/api/Enfoque";
        let modal = new bootstrap.Modal(document.getElementById('modalEnfoque'));
        let modoEditar = false;
        async function cargar() {

        const res = await fetch(api);
        const data = await res.json();

        let tabla = document.getElementById("tabla");
        tabla.innerHTML = "";

        data.forEach(e => {

        tabla.innerHTML += `
        <tr>
        <td>${e.id}</td>
        <td>${e.nombre ?? ""}</td>
        <td>${e.descripcion ?? ""}</td>
        <td>
        <button class="btn btn-warning btn-sm" onclick="editar('${e.id}')">Editar</button>
        <button class="btn btn-danger btn-sm" onclick="eliminar('${e.id}')">Eliminar</button>
        </td>
        </tr>
        `;
        });
        }

        function nuevo() {

        modoEditar = false;

        document.getElementById("id").value = "";
        document.getElementById("nombre").value = "";
        document.getElementById("descripcion").value = "";

        modal.show();
        }

        async function editar(id) {

        modoEditar = true;

        const res = await fetch(`${api}/${id}`);
        const data = await res.json();

        document.getElementById("id").value = data.id;
        document.getElementById("nombre").value = data.nombre;
        document.getElementById("descripcion").value = data.descripcion;

        modal.show();
        }

        async function guardar() {

        const id = document.getElementById("id").value;

        const enfoque = {
        id: parseInt(id),
        nombre: document.getElementById("nombre").value,
        descripcion: document.getElementById("descripcion").value
        };

        let response;

        if (modoEditar) {

        response = await fetch(`${api}/${id}`, {
        method: "PUT",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(enfoque)
        });

        } else {

        response = await fetch(api, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(enfoque)
        });

        }

        if (response.ok) {
        modal.hide();
        cargar();
        } else {
        const error = await response.text();
        alert("Error: " + error);
        }
        }

        async function eliminar(id) {

        if (!confirm("¿Eliminar registro?")) return;

        await fetch(`${api}/${id}`, {
        method: "DELETE"
        });

        cargar();
        }

        cargar();

    </script>

</body>

</html>